# -----------------------------------------------------------------------------
# Gym WhatsApp Automation API — Environment Configuration Template
# Copy this file to '.env' and fill in the values for local development.
# -----------------------------------------------------------------------------

# Application Settings
APP_NAME="Gym WhatsApp Automation API"
APP_ENV=development # development, staging, production
DEBUG=True

# Database Configuration (Supabase PostgreSQL / asyncpg connection string)
# Example: postgresql+asyncpg://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?ssl=require
DATABASE_URL="postgresql://user:password@host:5432/dbname"


# Security & Authentication (Generate secure keys using: openssl rand -hex 32)
JWT_SECRET_KEY="your-super-secret-access-token-key-change-me"
JWT_REFRESH_SECRET_KEY="your-super-secret-refresh-token-key-change-me"

# Expiration Configurations
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Fernet Encryption Key (Generate using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_SECRET_KEY="your-fernet-secret-key-must-be-32-url-safe-base64-encoded-bytes"

# CORS Origins (Comma-separated list of allowed URLs)
# Support local development and staging/production domains
ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"

# Meta (WhatsApp Cloud API) Integration Settings
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"
META_WEBHOOK_VERIFY_TOKEN="your-meta-webhook-verify-token"

# n8n Automation Integration Webhook
N8N_WEBHOOK_URL="https://n8n.yourdomain.com/webhook/..."

# Sentry Monitoring DSN (Leave blank in development to disable Sentry)
SENTRY_DSN=""
